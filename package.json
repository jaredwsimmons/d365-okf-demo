{
  "name": "d365-okf-demo",
  "version": "1.0.0",
  "private": true,
  "description": "Public, fully-synthetic (Contoso) demo of the D365 OKF static dashboard, published to GitHub Pages. Reads baked JSON snapshots — no database, no server at runtime.",
  "scripts": {
    "dev": "next dev",
    "build:static": "cross-env NEXT_PUBLIC_STATIC=1 node scripts/static/build-static.mjs",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx scripts/seed/load-json.ts",
    "db:setup": "docker compose up -d && npm run db:migrate && npm run db:seed",
    "snapshot": "node scripts/okf/build-snapshot.mjs"
  },
  "dependencies": {
    "@azure/identity": "^4.5.0",
    "@tanstack/react-form": "^1.29.1",
    "@tanstack/react-query": "^5.99.0",
    "@xyflow/react": "^12.10.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "d3": "^7.9.0",
    "drizzle-orm": "^0.44.0",
    "elkjs": "^0.11.0",
    "lucide-react": "^0.563.0",
    "next": "16.1.6",
    "pg": "^8.13.1",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/d3": "^7.4.3",
    "@types/node": "^20",
    "@types/pg": "^8.11.10",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^7.0.3",
    "drizzle-kit": "^0.31.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "tsx": "^4.19.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
